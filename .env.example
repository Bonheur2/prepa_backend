# PostgreSQL connection string (e.g. a Neon pooled connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require

# Long random string -- generate with: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_string

# Groq API key for the AI tutor endpoint
GROQ_API_KEY=replace_with_your_groq_api_key
CORS_ORIGIN=https://prepa-admin-dashboard.vercel.app

# Cloudflare R2 (S3-compatible object storage) for uploaded past-paper and
# document PDFs. Create a bucket + API token at dash.cloudflare.com -> R2.
R2_ACCOUNT_ID=replace_with_your_cloudflare_account_id
R2_ACCESS_KEY_ID=replace_with_your_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_your_r2_secret_access_key
R2_BUCKET_NAME=replace_with_your_bucket_name
R2_PUBLIC_URL_BASE=https://pub-xxxxxxxx.r2.dev
